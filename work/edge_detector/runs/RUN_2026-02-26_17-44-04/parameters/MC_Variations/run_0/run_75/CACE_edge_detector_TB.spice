** sch_path: /foss/designs/chipathon_2025/designs/ihp-sg13g2/edge_detector/runs/RUN_2026-02-26_17-44-04/parameters/MC_Variations/run_0/run_75/CACE_edge_detector_TB.sch
**.subckt CACE_edge_detector_TB
VIN net3 GND pwl 0 0 10n 0 10.1n {VDD}
VSP net1 GND {VDD}
VSN net2 GND {VSS}
* noconn Y
R3 net3 IN 50 m=1
R1 net2 VSS 50 m=1
R2 net1 VDD 50 m=1
xEDGE IN OUT VDD VSS edge_detector
*  xLOAD -  gate_inv_L0d5  IS MISSING !!!!
**** begin user architecture code




.control
    save all

    let Vhigh = 1.2
    let Vmid = Vhigh * 0.5

    let tstop = 20n
    let tstep = tstop/10k

    * Run transient analysis
    tran $&tstep $&tstop

    * Measure rising edge time (when OUT crosses threshold upwards)
    meas tran t_rise when v(OUT)=Vmid rise=1

    * Measure falling edge time (when OUT crosses threshold downwards)
    meas tran t_fall when v(OUT)=Vmid fall=1

    * Calculate pulse width as time difference
    let pulse_width=t_fall-t_rise

    * Save output
    echo $&pulse_width > /foss/designs/chipathon_2025/designs/ihp-sg13g2/edge_detector/runs/RUN_2026-02-26_17-44-04/parameters/MC_Variations/run_0/run_75/CACE_edge_detector_TB_0.data
.endc



