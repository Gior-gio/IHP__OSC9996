.include /foss/designs/chipathon_2025/designs/ihp-sg13g2/edge_detector/netlist/pex/edge_detector.spice

.temp 27

* Statitical switches
.param mm_ok=1
.param mc_ok=1
.option SEED=12421.0

* Flag unsafe operating conditions (exceeds models' specified limits)
.option warn=1



.param VDD = 1.2
.param VSS = 0


