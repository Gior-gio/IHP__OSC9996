** sch_path: /foss/designs/chipathon_2025/designs/ihp-sg13g2_playground/test_2_integrator_curstav_inv/xschem/test_2_integrator_curstav_inv.sch
.subckt test_2_integrator_curstav_inv

x1 VDD VcrtP out vout1 VcrtN VSS net4 integrator_curstav_inv
V1 VDD GND {VDD}
V2 VSS GND 0
x2 VDD VcrtP vout1 vout2 VcrtN VSS net5 integrator_curstav_inv
x3 VDD VcrtP vout2 vout3 VcrtN VSS net6 integrator_curstav_inv
V3 VcrtN GND {vcontrol}
x4 VDD VcrtP vout3 vout4 VcrtN VSS net7 integrator_curstav_inv
x5 VDD VcrtP vout4 out VcrtN VSS net8 integrator_curstav_inv
* noconn #net1
* noconn #net2
* noconn #net3
M4 VcrtP VcrtP VDD VDD sg13_lv_pmos w=2u l=0.13u ng=1 m=2
M1 VcrtP VcrtN VSS VSS sg13_lv_nmos w=1.0u l=0.13u ng=1 m=2
x6 VDD net1 vout1 out VSS gate_xor
x7 VDD net2 vout3 vout2 VSS gate_xor
x8 VDD net3 out vout4 VSS gate_xor
**** begin user architecture code

.lib cornerMOSlv.lib mos_tt



.TRAN 0.01n 1u
.param vcontrol = 1
.param v_start_stop = 0
.param cap=20u
.param VDD=1.5
.save v(out)

.control

**************************************************
*            PARÁMETROS GENERALES
**************************************************
let VP    = 1.8
let per50 = VP * 0.5

**************************************************
*     PARÁMETROS PARA EL BARRIDO DE vcontrol
*           (con w = 1u fijo)
**************************************************
let vstart   = 0
let vend     = VP
let vstep    = 0.083
let npoints  = (vend - vstart)/vstep + 1

let vpp      = vector(npoints)
let v        = vstart
let idx      = 0

* Crear vectores para almacenar resultados del barrido
let vcontrol_vec = vector(npoints)
let freq_vec     = vector(npoints)

settype voltage   vcontrol_vec
settype frequency freq_vec

alterparam w = 1u

**************************************************
*               BARRIDO DE vcontrol
**************************************************
while v le vend
    alterparam vcontrol = $&v
    reset
    tran 0.1n 0.8u

    meas TRAN T_period TRIG v(out) VAL=per50 rise=2 TARG v(out) VAL=per50 rise=3

    let F_recu             = 1 / T_period
    let vcontrol_vec[idx]  = v
    let freq_vec[idx]      = F_recu
    let vpp[idx]           = $v(vp)

    let v   = v + vstep
    let idx = idx + 1
end

**************************************************
*                  GRÁFICAS
**************************************************
plot freq_vec vs vcontrol_vec

print vcontrol_vec freq_vec vpp

.endc


**** end user architecture code
.ends

